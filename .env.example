# =============================================================================
# Scraping — Chrome, profile, JobRight / Glassdoor / ZipRecruiter
# =============================================================================

CHROME_APP_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Dedicated scraping profile (omit to use <repo>/zata/chromeData/irangarick)
SCRAPING_CHROME_DIR=C:\\Users\\location\\Desktop\\Saral-Job-Viewer\\zata\\irangarick
SCRAPING_PORT=9003

DATA_DIR=zata

# Scraper search keywords are managed in MongoDB via Admin UI.

SCRAPING_STALE_RETRIES=3
SCRAPING_STALE_DELAY=0.85

SCRAPING_HEADLESS=0
CLOSE_ON_COMPLETE=1

# =============================================================================
# Database & Midhtech — job storage (MongoDB), MAAS login (validation.py / suggest)
# =============================================================================

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=SaralJobViewer
MONGODB_DATABASE=saralJobViewer
JWT_SECRET=replace-with-a-long-random-secret

MIDHTECH_EMAIL=your-email@example.com
MIDHTECH_PASSWORD=your-password

# =============================================================================
# Site + API (nginx terminates SSL; /api proxied to FastAPI)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=9260
VITE_API_URL=https://saral.thatinsaneguy.com
SARAL_API_BASE_URL=https://saral.thatinsaneguy.com

# nginx + Let's Encrypt (./deploy.sh)
# DNS A record for SARAL_DOMAIN must point at this host before first deploy.
# On a shared server (system nginx already on :80), run: sudo ./deploy.sh
SARAL_DOMAIN=saral.thatinsaneguy.com
SARAL_SSL_EMAIL=you@thatinsaneguy.com

# =============================================================================
# Redis (internal Docker network)
# =============================================================================
REDIS_ENABLED=true
REDIS_URL=redis://sjv-redis:9262/0
REDIS_PREFIX=sjv
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_CONNECT_TIMEOUT_MS=500
REDIS_SOCKET_TIMEOUT_MS=500

# Validation containers (triggered from Admin UI)
VALIDATION_IMAGE=saral-dvalidate:latest
VALIDATION_DOCKER_NETWORK=saral-job-viewer_sjv-net
