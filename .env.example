# =============================================================================
# Scraping — Chrome, profile, JobRight / Glassdoor / ZipRecruiter
# =============================================================================

CHROME_APP_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Dedicated scraping profile (omit to use <repo>/zata/chromeData/irangarick)
SCRAPING_CHROME_DIR=C:\\Users\\location\\Desktop\\Saral-Job-Viewer\\zata\\irangarick
SCRAPING_PORT=9003

DATA_DIR=zata

# Comma- or pipe-separated keywords; scrapers run sequential phases per keyword.
SCRAPER_SEARCH_KEYWORDS=devops, cloud engineer, site reliability engineer, database administrator, platform engineer

SCRAPING_STALE_RETRIES=3
SCRAPING_STALE_DELAY=0.85

SCRAPING_HEADLESS=0
CLOSE_ON_COMPLETE=1

# =============================================================================
# Database & Midhtech — job storage (MongoDB), MAAS login (validation.py / suggest)
# =============================================================================

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=SaralJobViewer
MONGODB_DATABASE=saralJobViewer
JWT_SECRET=replace-with-a-long-random-secret

MIDHTECH_EMAIL=your-email@example.com
MIDHTECH_PASSWORD=your-password

# =============================================================================
# Job viewer API (FastAPI: python app.py) — CORS allows all origins (*)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# Local dev: backend origin. Production SPA build: set to Cloud Run API URL (see docs/DeployFrontendWindows.md).
VITE_API_URL=http://127.0.0.1:8000

# =============================================================================
# Redis cache (local default)
# =============================================================================
REDIS_ENABLED=true
REDIS_URL=redis://sjv-redis:6379/0
REDIS_PREFIX=sjv
REDIS_DEFAULT_TTL_SECONDS=60
REDIS_CONNECT_TIMEOUT_MS=500
REDIS_SOCKET_TIMEOUT_MS=500

# Cloud Run Job trigger (API container).
# Keep this container path fixed; deploy.sh mounts host file -> /app/secrets/gcp-sa.json.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-sa.json
GCP_PROJECT_ID=saraljobviewer
GCP_REGION=us-east1
RUN_JOB_NAME=saral-dvalidate-job