# Chrome Configuration for LinkedIn Scraping
CHROME_APP_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Scraping Chrome profile (omit to use <repo>/zata/chromeData/irangarick)
SCRAPING_CHROME_DIR=C:\\Users\\utsav\\OneDrive\\Desktop\\Saral-Job-Viewer\\zata\\irangarick
SCRAPING_PORT=9003

DATA_DIR=zata

# Comma- or pipe-separated job title keywords for JobRight, Glassdoor, ZipRecruiter (sequential phases).
SCRAPER_SEARCH_KEYWORDS=devops, cloud engineer, site reliability engineer, database administrator, platform engineer

SCRAPING_STALE_RETRIES = 3
SCRAPING_STALE_DELAY = 0.85

SCRAPING_HEADLESS = 0  # set to 0 to show the browser window (headed mode).
CLOSE_ON_COMPLETE = 1  # 0 = wait for Enter (default).

# Job storage: sqlite (default file zata/saralJobViewer.db) or mongo (Atlas / self-hosted).
# DATABASE=sqlite
DATABASE=mongo
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=SaralJobViewer
MONGODB_DATABASE=saralJobViewer

